# Database connection string
DATABASE_URI=postgres://postgres:postgres@localhost:5432/<your-db-name>

# Used to encrypt JWT tokens
PAYLOAD_SECRET=YOUR_SECRET_HERE

# Used to configure CORS, format links and more. No trailing slash
NEXT_PUBLIC_SERVER_URL=http://localhost:3000

# ── Staging-only ─────────────────────────────────────────────────────────────
# Set these in Railway staging environment variables only — never in production.

# Enables the ?tenant= query param override for browsing tenant frontends
# on staging without owning their domains.
# TENANT_SLUG_OVERRIDE_ENABLED=true

# Optional secret that must be passed as ?secret= alongside ?tenant=.
# If set, the override is inaccessible without the correct value.
# STAGING_PREVIEW_SECRET=change-me

# HTTP Basic Auth protecting the entire staging site (including /admin and /api).
# When set, the browser will prompt for credentials before serving any page.
# STAGING_BASIC_AUTH_USER=staging
# STAGING_BASIC_AUTH_PASS=change-me
